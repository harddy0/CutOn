{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": ".venv\\Scripts\\activate.bat && uvicorn app.main:app --reload --port 8000",
    "dev:worker": ".venv\\Scripts\\activate.bat && celery -A app.celery_app worker -Q embeddings --loglevel=info",
    "db:reset": ".venv\\Scripts\\activate.bat && python -m app.db.reset",
    "start": ".venv\\Scripts\\activate.bat && uvicorn app.main:app --host 0.0.0.0 --port 8000",
    "start:worker": ".venv\\Scripts\\activate.bat && celery -A app.celery_app worker -Q embeddings --loglevel=info"
  }
}
