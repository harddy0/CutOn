# ── CutOn Backend — Environment Variables ─────────────────────────────
# Copy to .env and fill in your values.

# ── Project ────────────────────────────────────────────────────────────
PROJECT_NAME="CutOn Backend"

# ── MongoDB ───────────────────────────────────────────────────────────
MONGO_URI="mongodb://localhost:27017"
MONGO_DB_NAME="cuton_db"

# ── JWT (Authentication) ──────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET="change-me-in-production"
JWT_ALGORITHM="HS256"
# Token expiry in minutes (1440 = 24h)
JWT_EXPIRE_MINUTES=1440

# ── Google AI Studio (Gemini) ─────────────────────────────────────────
# Get your API key: https://aistudio.google.com/apikey
GEMINI_API_KEY="your_google_ai_studio_api_key"
GEMINI_MODEL="gemini-1.5-flash"

# ── Optional Thinking Level ────────────────────────────────────────────
# For reasoning-capable models (e.g. gemma models).
#   "enabled"       → thinking_level: "medium"
#   "minimal"|"low"|"medium"|"high"  → pass through directly
#   "1024" (number) → thinking_budget: 1024 (token-budget reasoning)
#   (empty/unset)   → no thinking override (model default)
AI_THINKING_LEVEL=""

# ── Embeddings ─────────────────────────────────────────────────────────
EMBEDDING_MODEL="gemini-embedding-2-flash"

# ── Redis ──────────────────────────────────────────────────────────────
# Full connection URL (takes priority over individual params below)
REDIS_URL="redis://localhost:6379/0"

# Individual params (used when REDIS_URL is empty)
# REDIS_HOST="localhost"
# REDIS_PORT=6379
# REDIS_PASSWORD=""
# REDIS_USERNAME=""
# REDIS_DB=0
# REDIS_SSL=false

# ── Celery (Background Workers) ────────────────────────────────────────
# Max retries before marking task as FAILED in DB
CELERY_MAX_RETRIES=5
# Base backoff seconds (doubles per retry: 60s → 120s → 240s)
CELERY_RETRY_BACKOFF_SEC=60

# ── CORS ───────────────────────────────────────────────────────────────
# Comma-separated origins or * for dev
CORS_ORIGINS="*"

# ── File Upload ────────────────────────────────────────────────────────
# Max upload size in MB
MAX_UPLOAD_SIZE_MB=50
# Comma-separated allowed file types
ALLOWED_FILE_TYPES="pdf,docx,txt"

# ── Text Chunking ─────────────────────────────────────────────────────
# Characters per chunk
CHUNK_SIZE=1000
# Overlap characters between adjacent chunks
CHUNK_OVERLAP=200
