# ── CutOn Backend — Environment Variables ─────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ── Project ────────────────────────────────────────────────────────────
PROJECT_NAME="CutOn Backend"

# ── MongoDB ───────────────────────────────────────────────────────────
MONGO_URI="mongodb://localhost:27017"
MONGO_DB_NAME="cuton_db"

# ── JWT (Authentication) ──────────────────────────────────────────────
# Generate a strong secret:  openssl rand -hex 32
JWT_SECRET="change-me-in-production"
JWT_ALGORITHM="HS256"
# Token expiry in minutes (1440 = 24 hours)
JWT_EXPIRE_MINUTES=1440

# ── Google AI Studio (Gemini) ─────────────────────────────────────────
# Get your API key: https://aistudio.google.com/apikey
GEMINI_API_KEY="your_google_ai_studio_api_key"
GEMINI_MODEL="gemini-1.5-flash"

# ── Embeddings (Cloud) ────────────────────────────────────────────────
# The embedding model used to generate chunk and journal-entry vectors.
# Default: gemini-embedding-2-flash (Google's multimodal embedding model)
# Options:
#   Gemini:         gemini-embedding-2-flash, gemini-embedding-2
#   Google Vertex:  models/text-embedding-004, models/text-embedding-005
#   OpenAI:         text-embedding-3-small, text-embedding-3-large
#   Voyage:         voyage-3, voyage-3-lite
#   Cohere:         embed-english-v3.0, embed-multilingual-v3.0
EMBEDDING_MODEL="gemini-embedding-2-flash"  # Changed to Gemini's dedicated embedding model

# ── Redis ──────────────────────────────────────────────────────────────
# OPTION A — Full connection URL (takes priority over individual params)
REDIS_URL="redis://localhost:6379/0"
#
# OPTION B — Individual connection parameters (used when REDIS_URL is empty)
# REDIS_HOST="localhost"
# REDIS_PORT=6379
# REDIS_PASSWORD=""
# REDIS_USERNAME=""
# REDIS_DB=0
# REDIS_SSL=false

# ── Celery (Background Workers) ────────────────────────────────────────
# Maximum retries for failed background tasks (e.g. embedding generation)
# After exhausting retries, the task status is set to FAILED in the DB.
CELERY_MAX_RETRIES=5
# Base backoff interval in seconds (doubles on each retry: 60s → 120s → 240s …)
CELERY_RETRY_BACKOFF_SEC=60

# ── CORS ───────────────────────────────────────────────────────────────
# Comma-separated origins or * for all (development only)
CORS_ORIGINS="*"
