# Environment & Observability
ENVIRONMENT=development                              # development | staging | production
LOG_LEVEL=INFO                                        # DEBUG | INFO | WARNING | ERROR
SENTRY_DSN=                                           # https://key@oXXX.ingest.sentry.io/XXX (leave empty to disable)
SENTRY_TRACES_SAMPLE_RATE=0.1                         # 0.0 (none) to 1.0 (all traces)

# ── MongoDB ──────────────────────────────────────────────────────────
# Local:      mongodb://localhost:27017
# Atlas:      mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=cuton_db

# ── JWT ──────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440          # 24 hours

# ── Google AI Studio (Gemini) ────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
AI_THINKING_LEVEL=

# ── Embeddings ───────────────────────────────────────────────────────
EMBEDDING_MODEL=gemini-embedding-2-flash

# ── Redis ────────────────────────────────────────────────────────────
# Set REDIS_URL to use a single connection string (takes priority)
# REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USERNAME=
REDIS_DB=0
REDIS_SSL=false
REDIS_MAX_CONNECTIONS=10
REDIS_SOCKET_TIMEOUT_SEC=2
REDIS_SOCKET_CONNECT_TIMEOUT_SEC=2

# ── Celery ───────────────────────────────────────────────────────────
CELERY_MAX_RETRIES=5
CELERY_RETRY_BACKOFF_SEC=60
CELERY_RETRY_BACKOFF_MAX_SEC=3600

# ── File Upload ──────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
ALLOWED_FILE_TYPES=pdf,docx,txt

# ── Text Chunking ────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── Rate Limiting ────────────────────────────────────────────────────
RATE_LIMIT_RETRY_AFTER_SEC=60

# ── Dashboard Cache TTLs (seconds) ──────────────────────────────────
CACHE_TTL_SUMMARY_SEC=30
CACHE_TTL_LEARNING_SEC=60
CACHE_TTL_QUIZ_SEC=300
CACHE_TTL_RAG_SEC=300
CACHE_TTL_ACTIVITY_SEC=30

# ── CORS ─────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ── Brevo (Transactional Email) ─────────────────────────────────────
BREVO_API_KEY=
EMAIL_FROM_ADDRESS=noreply@cuton.app
EMAIL_FROM_NAME=CutOn

# ── Password Reset ───────────────────────────────────────────────────
RESET_TOKEN_EXPIRE_MINUTES=60
FRONTEND_URL=http://localhost:5173